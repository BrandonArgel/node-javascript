{
  "name": "express-javascript",
  "version": "1.0.0",
  "description": "Learning Node.js",
  "keywords": [
    "node",
    "nodejs"
  ],
  "license": "ISC",
  "author": "Brandon Argel Verdeja Domínguez",
  "type": "module",
  "main": "src/index.js",
  "imports": {
    "#config/*": "./src/config/*",
    "#middlewares/*": "./src/middlewares/*",
    "#models/*": "./src/models/*",
    "#repositories/*": "./src/repositories/*",
    "#routes/*": "./src/routes/*",
    "#validations/*": "./src/validations/*",
    "#utils/*": "./src/utils/*"
  },
  "scripts": {
    "dev": "node --watch-path=./src --env-file=.env src/index.js",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "db-local": "^3.1.0",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "standard": "^17.1.2"
  },
  "eslintConfig": {
    "extends": "standard"
  }
}
